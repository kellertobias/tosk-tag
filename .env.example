# Local build settings for ./build.

# Prefer full Xcode over Command Line Tools so SwiftPM uses a matching SDK.
DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer

# Keep compiler cache output inside the repo build folder.
CLANG_MODULE_CACHE_PATH=.build/module-cache

# Where ./build archive install copies the archived app.
INSTALL_DIR="/Applications/Weitere"

# Ad-hoc signing is enough for local archive/run/install builds.
CODE_SIGN_IDENTITY=-

# Developer ID signing identity for ./build distribute.
DISTRIBUTION_CERTIFICATE="Developer ID Application"

# Optional notarization settings for ./build distribute.
# NOTARY_KEYCHAIN_PROFILE=tag-editor-notary
# NOTARY_APPLE_ID=you@example.com
# NOTARY_TEAM_ID=TEAMID1234
# NOTARY_PASSWORD=app-specific-password
